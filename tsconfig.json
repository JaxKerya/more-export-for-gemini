{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false,
    "types": ["chrome"]
  },
  "include": [
    "src/lib/settings.js",
    "src/lib/export-opts.js",
    "src/lib/source-hygiene.js",
    "src/global.d.ts"
  ],
  "exclude": ["src/vendor/**"]
}
