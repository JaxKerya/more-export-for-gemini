# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build / package output ──────────────────────────────────
store/*.zip

# ── Test & validation scratch (regenerated on demand) ───────
# Everything under validate/ is generated output (debug matrix exports,
# rendered PDFs/HTML, ad-hoc re-validation files) — never commit it.
validate/
Manuel-Validate/

# ── Tooling caches ───────────────────────────────────────────
.eslintcache
*.tsbuildinfo
npm-debug.log*

# ── LaTeX / external validator artifacts ─────────────────────
*.aux
*.log
*.out
*.fdb_latexmk
*.fls
*.synctex.gz

# ── OS clutter ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE / AI-agent config (local only) ─────────────
.cursor/
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Secrets (never commit) ───────────────────────────────────
.env
.env.*
*.pem
credentials.json
