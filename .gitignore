# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build / package output ──────────────────────────────────
store/*.zip

# ── Test & validation scratch (regenerated on demand) ───────
# Golden files in validate/debug and validate/render stay tracked;
# only ad-hoc export/re-validation output is ignored.
validate/output/
validate/tp/
validate/tpbin/
Manuel-Validate/

# ── Tooling caches ───────────────────────────────────────────
.eslintcache
*.tsbuildinfo
npm-debug.log*

# ── LaTeX / external validator artifacts ─────────────────────
*.aux
*.log
*.out
*.fdb_latexmk
*.fls
*.synctex.gz

# ── OS clutter ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Secrets (never commit) ───────────────────────────────────
.env
.env.*
*.pem
credentials.json
